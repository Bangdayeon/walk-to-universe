    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5"
